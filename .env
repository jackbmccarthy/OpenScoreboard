# Firebase Configuration
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://your-project.firebaseio.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123

# Use local AceBase database instead of Firebase
VITE_USE_LOCAL_DB=false

# AceBase local settings (used when VITE_USE_LOCAL_DB=true)
VITE_ACEBASE_HOST=localhost
VITE_ACEBASE_PORT=8080
VITE_ACEBASE_USE_SSL=false
VITE_DATABASE_NAME=openscoreboard
