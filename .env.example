# OpenScoreboard Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# DATABASE CONFIGURATION
# ===========================================

# Set to true for local AceBase, false for Firebase cloud
VITE_USE_LOCAL_DB=false

# ===========================================
# FIREBASE (Cloud - use these when VITE_USE_LOCAL_DB=false)
# ===========================================
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ===========================================
# ACEBASE (Local - use these when VITE_USE_LOCAL_DB=true)
# ===========================================
VITE_ACEBASE_HOST=localhost
VITE_ACEBASE_PORT=3434
VITE_ACEBASE_HTTPS=false
VITE_ACEBASE_DEBUG=false
VITE_ACEBASE_DATABASE_NAME=openscoreboard
