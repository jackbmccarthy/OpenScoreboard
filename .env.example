# OpenScoreboard Environment Variables
# Vite automatically exposes VITE_* variables to client-side code
# Variables without VITE_ prefix can be used as fallback

# ===========================================
# OPTION 1: Base Firebase variables (without VITE_ prefix)
# If these are set, VITE_ versions will inherit from these
# ===========================================
# FIREBASE_API_KEY=your_api_key
# FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
# FIREBASE_DATABASE_URL=https://your-project.firebaseio.com
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_STORAGE_BUCKET=your-project.appspot.com
# FIREBASE_MESSAGING_SENDER_ID=123456789
# FIREBASE_APP_ID=1:123456789:web:abc123

# ===========================================
# OPTION 2: VITE_ prefixed variables (direct)
# Set these explicitly in Coolify or use .env file
# ===========================================
VITE_USE_LOCAL_DB=false
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ===========================================
# LOCAL DATABASE (AceBase)
# Used when VITE_USE_LOCAL_DB=true
# ===========================================
VITE_ACEBASE_HOST=localhost
VITE_ACEBASE_PORT=8080
VITE_ACEBASE_USE_SSL=false
VITE_DATABASE_NAME=openscoreboard
