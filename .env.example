# OpenScoreboard v3 Environment Variables
# Copy this file to .env and fill in your values
# Then set these same variables in Coolify

# ===========================================
# FIREBASE
# ===========================================
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://your-project.firebaseio.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123

# ===========================================
# DATABASE MODE
# false = Firebase cloud, true = local AceBase
# ===========================================
VITE_USE_LOCAL_DB=false

# ===========================================
# ACEBASE (used when VITE_USE_LOCAL_DB=true)
# ===========================================
VITE_ACEBASE_HOST=localhost
VITE_ACEBASE_PORT=8080
VITE_ACEBASE_USE_SSL=false
VITE_DATABASE_NAME=openscoreboard
