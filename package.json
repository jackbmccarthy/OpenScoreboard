{
  "name": "openscoreboard",
  "version": "3.0.0",
  "private": true,
  "description": "Open Scoreboard is a software that allows users to create custom scoreboards that can be added to live streams or other forms of video content, and providing a scorekeeping interface to allow for real time updates to scores.",
  "scripts": {
    "dev": "concurrently --kill-others \"npm run dev:server\" \"npm run dev:next\" \"npm run dev:editor\" \"npm run dev:scoreboard\"",
    "dev:server": "ts-node-dev --respawn --transpile-only server.ts",
    "dev:next": "next dev -p 3000",
    "dev:editor": "cd openscoreboard-editor && vite --port 3005",
    "dev:scoreboard": "cd openscoreboard-scoreboard && vite --port 3002",
    "build": "npm run build:next && npm run build:editor && npm run build:scoreboard",
    "build:next": "next build",
    "build:editor": "cd openscoreboard-editor && vite build",
    "build:scoreboard": "cd openscoreboard-scoreboard && vite build",
    "start": "node .next/standalone/server.js",
    "start:dev": "dotenvx run --env-file=./.env.development -- ts-node server.ts"
  },
  "dependencies": {
    "@auth/core": "^0.34.3",
    "@dotenvx/dotenvx": "^0.21.0",
    "acebase": "^1.26.2",
    "acebase-client": "^1.20.0",
    "acebase-server": "github:jackbmccarthy/acebase-server#master",
    "autoprefixer": "^10.4.27",
    "axios": "^1.1.3",
    "concurrently": "^8.2.2",
    "express": "^4.18.2",
    "firebase": "8.10.1",
    "firebaseui": "5.0.0",
    "http-proxy-middleware": "^3.0.5",
    "i18n-js": "^4.2.3",
    "next": "^15.5.14",
    "next-auth": "^4.24.7",
    "node-html-parser": "^6.1.1",
    "postcss": "^8.5.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^3.4.19",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.12.9",
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/parser": "^7.0.2",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.5",
    "ts-node-dev": "^2.0.0",
    "webpack-bundle-analyzer": "^4.8.0"
  }
}
